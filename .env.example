# Copy this file to .env and adjust any values that conflict with your setup.
# All values shown are the defaults — you only need to set what you want to change.

# Host ports for each service.
# 9090 is commonly used by other monitoring tools (Node Exporter, Prometheus
# instances, etc.). Change PROMETHEUS_PORT if something else is already there.
GRAFANA_PORT=3000
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200
