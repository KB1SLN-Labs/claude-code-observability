# Grafana Cloud connection details
# Copy this file to .env.grafana-cloud and fill in your values.
# Find these on grafana.com -> your org -> loftymacaron2758 (or your stack name) -> Details for each service.

GC_PROMETHEUS_ENDPOINT=https://prometheus-prod-XX-prod-us-east-2.grafana.net/api/prom/push
GC_PROMETHEUS_USER=<numeric instance ID from Prometheus Details page>

GC_LOKI_ENDPOINT=https://logs-prod-XXX.grafana.net/loki/api/v1/push
GC_LOKI_USER=<numeric user ID from Loki Details page>

# API token — create at grafana.com -> Access Policies, scopes: metrics:write, logs:write
GC_API_TOKEN=<your grafana cloud api token>
