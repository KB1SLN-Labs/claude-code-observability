    {
      "id": 26,
      "type": "timeseries",
      "title": "Cache Hit Rate Over Time",
      "description": "Cache hit rate trend over the selected window. Sustained drops below 80% are a signal to restructure long sessions — cache is not being reused effectively. A sudden drop mid-session usually means a large new block of text invalidated the cache.",
      "gridPos": { "x": 0, "y": 41, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 1,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "line+area" }
