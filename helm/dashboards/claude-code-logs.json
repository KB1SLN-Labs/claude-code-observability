{
  "annotations": { "list": [] },
  "description": "Claude Code raw log stream — filter by level and session ID to investigate errors and activity",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "arrow-left",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "← Claude Code",
      "tooltip": "Back to main dashboard",
      "type": "link",
      "url": "/d/claude-code-observability"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["claude-code"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Claude Code — Logs",
  "uid": "claude-code-logs",
  "version": 1,
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Loki",
        "multi": false,
        "name": "loki_datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Level",
        "multi": false,
        "name": "level",
        "options": [
          { "selected": false, "text": "error", "value": "error" },
          { "selected": false, "text": "warn", "value": "warn" },
          { "selected": false, "text": "info", "value": "info" },
          { "selected": false, "text": "debug", "value": "debug" }
        ],
        "query": "error,warn,info,debug",
        "skipUrlSync": false,
        "type": "custom"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Session ID",
        "name": "session_id",
        "options": [],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Errors",
      "description": "Total error-level log entries in the selected time range.",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "sum(count_over_time({job=\"claude-code\"} |~ \"(?i)error\" [$__range]))",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Warnings",
      "description": "Total warn-level log entries in the selected time range.",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "orange", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "sum(count_over_time({job=\"claude-code\"} |~ \"(?i)warn\" [$__range]))",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Entries",
      "description": "Total log entries from Claude Code in the selected time range.",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "text", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "sum(count_over_time({job=\"claude-code\"} [$__range]))",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Sessions",
      "description": "Distinct session_id values seen in logs during the selected time range.",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "text", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "sum(count_over_time({job=\"claude-code\"} | json | __error__=\"\" [$__range]))",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Log Volume Over Time",
      "description": "Log entries per minute broken down by severity. Error and warning spikes are the signal to open the log stream below and investigate.",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "errors" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "warnings" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "total" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "sum(count_over_time({job=\"claude-code\"} |~ \"(?i)error\" [1m]))",
          "legendFormat": "errors",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "sum(count_over_time({job=\"claude-code\"} |~ \"(?i)warn\" [1m]))",
          "legendFormat": "warnings",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "sum(count_over_time({job=\"claude-code\"} [1m]))",
          "legendFormat": "total",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Log Stream",
      "description": "Filtered log entries. Set Level to narrow by severity; paste a session ID to scope to a single session. Click any row to expand the full structured payload.",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 18 },
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "{job=\"claude-code\"} |~ \"(?i)${level}\" |= \"${session_id}\"",
          "refId": "A"
        }
      ]
    }
  ]
}
